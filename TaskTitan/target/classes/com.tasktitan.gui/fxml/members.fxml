<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<AnchorPane fx:id="root" prefHeight="800.0" prefWidth="1400.0" style="-fx-background-color: #102636; -fx-background-radius: 20; -fx-padding: 25;" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.tasktitan.gui.controllers.MembersController">
   <children>
      <VBox prefHeight="800.0" prefWidth="1400.0" spacing="15.0" style="-fx-background-color: #102636; -fx-background-radius: 18; -fx-padding: 20;" AnchorPane.bottomAnchor="20.0" AnchorPane.leftAnchor="20.0" AnchorPane.rightAnchor="20.0" AnchorPane.topAnchor="20.0">
         <children>
            <HBox alignment="CENTER_LEFT" prefHeight="100.0" prefWidth="200.0" spacing="20.0">
               <children>
                  <Label style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: white;" text="Members" />
                  <Region prefHeight="200.0" prefWidth="200.0" HBox.hgrow="ALWAYS" />
                  <Button fx:id="addMemberButton" mnemonicParsing="false" onAction="#openAddMember" style="-fx-background-color: #00E5FF; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 10; -fx-font-size: 20; -fx-padding: 10 20; -fx-cursor: hand;" text="✚ Add Member" />
               </children>
            </HBox>
            <TableView fx:id="membersTable" prefHeight="400.0" prefWidth="1100.0" style="-fx-background-color: #102636; -fx-control-inner-background: #102636; -fx-text-background-color: white; -fx-table-cell-border-color: transparent;" stylesheets="@../css/table.css" VBox.vgrow="ALWAYS">
              <columns>
                <TableColumn fx:id="nameColumn" prefWidth="200.0" text="Name" />
                <TableColumn fx:id="emailColumn" prefWidth="350.0" text="Email" />
                  <TableColumn fx:id="roleColumn" prefWidth="200.0" text="Role" />
              </columns>
               <columnResizePolicy>
                  <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
               </columnResizePolicy>
            </TableView>
            <HBox prefHeight="100.0" prefWidth="200.0">
               <children>
                  <Button fx:id="deleteMemberButton" mnemonicParsing="false" onAction="#deleteMember" style="-fx-background-color: #D9534F; -fx-text-fill: white; -fx-background-radius: 10; -fx-font-size: 16; -fx-cursor: hand;" text="Delete Selected" />
               </children>
            </HBox>
         </children>
      </VBox>
   </children>
</AnchorPane>
