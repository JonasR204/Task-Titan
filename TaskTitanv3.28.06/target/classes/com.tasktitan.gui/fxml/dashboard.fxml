<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<StackPane fx:id="rootStack" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.tasktitan.gui.controllers.DashboardController">

   <BorderPane fx:id="rootPane" style="-fx-background-color: #06131c;">
   <left>
      <VBox prefHeight="840.0" prefWidth="289.0" spacing="20.0" style="-fx-background-color: #071722; -fx-padding: 20;" BorderPane.alignment="CENTER">
         <children>
            <ImageView fitHeight="101.0" fitWidth="242.0" pickOnBounds="true" preserveRatio="true">
               <image>
                  <Image url="@../images/logo.png" />
               </image>
            </ImageView>
            <Button graphicTextGap="10.0" layoutX="30.0" layoutY="133.0" mnemonicParsing="false" onAction="#openDashboard" prefHeight="123.0" prefWidth="289.0" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 30px; -fx-alignment: center; -fx-padding: 15; fx-background-radius: 10; -fx-cursor: hand;" styleClass="sidebar-btn" stylesheets="@../css/dashboard.css" text="Dashboard">
                  <graphic>
                     <ImageView fitHeight="45.0" fitWidth="45.0" pickOnBounds="true" preserveRatio="true">
                        <image>
                           <Image url="@../images/Dashboard%20icon.png" />
                        </image>
                     </ImageView>
                  </graphic>
                  <padding>
                     <Insets left="25.0" />
                  </padding>
                  <font>
                     <Font size="18.0" />
                  </font></Button>
            <Button fx:id="StatisticsButton" graphicTextGap="10.0" layoutX="30.0" layoutY="419.0" mnemonicParsing="false" onAction="#openStatistics" prefHeight="123.0" prefWidth="289.0" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 30px; -fx-alignment: center; -fx-padding: 15; fx-background-radius: 10; -fx-cursor: hand;" styleClass="sidebar-btn" stylesheets="@../css/dashboard.css" text="Statistics">
                  <graphic>
                     <ImageView fitHeight="45.0" fitWidth="45.0" pickOnBounds="true" preserveRatio="true">
                        <image>
                           <Image url="@../images/statistics%20icon.png" />
                        </image>
                     </ImageView>
                  </graphic></Button>
            <Button fx:id="teamMembersButton" graphicTextGap="10.0" layoutX="30.0" layoutY="562.0" mnemonicParsing="false" onAction="#openTeamMembers" prefHeight="123.0" prefWidth="289.0" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 30px; -fx-alignment: center; -fx-padding: 15; fx-background-radius: 10; -fx-cursor: hand;" styleClass="sidebar-btn" stylesheets="@../css/dashboard.css" text="Members">
                  <graphic>
                     <ImageView fitHeight="45.0" fitWidth="45.0" pickOnBounds="true" preserveRatio="true">
                        <image>
                           <Image url="@../images/Members%20icon.png" />
                        </image>
                     </ImageView>
                  </graphic></Button>
         </children>
      </VBox>
   </left>
   <center>
      <BorderPane style="-fx-background-color: #06131c;" BorderPane.alignment="CENTER">
         <center>
               <StackPane fx:id="contentPane" BorderPane.alignment="CENTER">
                  <children>
                  <VBox prefHeight="200.0" prefWidth="100.0" spacing="40.0" style="-fx-padding: 20;">
                     <children>
                           <HBox prefHeight="97.0" prefWidth="805.0" spacing="15.0" style="-fx-padding: 20;">
                              <children>
                                 <Label prefHeight="97.0" prefWidth="359.0" style="-fx-font-size: 28; -fx-text-fill: white; -fx-font-weight: bold;" text="       Dashboard" HBox.hgrow="ALWAYS" />
                                 <Region prefHeight="200.0" prefWidth="200.0" HBox.hgrow="ALWAYS" />
                                 <HBox prefHeight="50.0" prefWidth="550.0" style="-fx-background-color: #0d2433; -fx-background-radius: 12; -fx-border-radius: 12; -fx-border-color: #1d3544; -fx-padding: 0 10 0 10;">
                                    <children>
                                       <ImageView fitHeight="40.0" fitWidth="40.0" pickOnBounds="true" preserveRatio="true">
                                          <image>
                                             <Image url="@../images/Search%20icon.png" />
                                          </image>
                                          <HBox.margin>
                                             <Insets bottom="5.0" left="5.0" right="10.0" top="8.0" />
                                          </HBox.margin>
                                       </ImageView>
                                       <TextField prefWidth="350.0" promptText="Search tasks..." style="-fx-background-color: transparent; -fx-text-fill: white; -fx-prompt-text-fill: #7F8FA4; -fx-border-color: transparent;">
                                          <font>
                                             <Font size="24.0" />
                                          </font>
                                       </TextField>
                                       <Region prefHeight="40.0" prefWidth="1.0" style="-fx-background-color: #14314D;" />
                                       <ComboBox fx:id="statusFilter" prefHeight="35.0" prefWidth="180.0" promptText="Status" style="-fx-background-color: transparent; -fx-text-fill: white;" styleClass="filter-combo" />
                                       <Region layoutX="252.0" layoutY="11.0" prefHeight="40.0" prefWidth="1.0" style="-fx-background-color: #14314D;" />
                                       <ComboBox fx:id="priorityFilter" layoutX="244.0" layoutY="11.0" prefHeight="35.0" prefWidth="150.0" promptText="Priority" style="-fx-background-color: transparent; -fx-text-fill: white;" styleClass="filter-combo" />
                                    </children>
                                 </HBox>
                                 <Region prefHeight="57.0" prefWidth="123.0" HBox.hgrow="ALWAYS" />
                                 <Button mnemonicParsing="false" onAction="#openAddTask" prefHeight="97.0" prefWidth="217.0" style="-fx-background-color: #00E5FF; -fx-text-fill: white; -fx-font-size: 20; -fx-background-radius: 10; -fx-padding: 10 20; -fx-cursor: hand;" text="✚">
                                    <font>
                                       <Font size="20.0" />
                                    </font>
                                 </Button>
                              </children>
                           </HBox>
                           <TableView fx:id="taskTable" prefHeight="691.0" prefWidth="384.0" stylesheets="@../css/dashboard.css" style="-fx-table-cell-border-color:transparent;">
                             <columns>
                               <TableColumn fx:id="taskColumn" prefWidth="190.0" text="Task" />
                               <TableColumn fx:id="typeColumn" prefWidth="126.0" text="Type" />
                                 <TableColumn fx:id="priorityColumn" prefWidth="164.0" text="Priority" />
                                 <TableColumn fx:id="assignedColumn" prefWidth="180.0" text="Assigned to" />
                                 <TableColumn fx:id="deadlineColumn" prefWidth="140.0" text="Deadline" />
                                 <TableColumn fx:id="statusColumn" prefWidth="140.0" text="Status" />
                                 <TableColumn fx:id="actionsColumn" prefWidth="180.0" text="Actions" />
                             </columns>
                           </TableView>
                     </children>
                  </VBox>
                  </children>
               </StackPane>
         </center>
      </BorderPane>
   </center>
</BorderPane>
</StackPane>
